---
// src/components/Waline.astro
---
<div id="waline"></div>

<script>
    import { init } from '@waline/client';
    import '@waline/client/style';
    import '../styles/waline.css';

    const managerKey = '__walineManager';

    const createManager = () => {
        let walineInstance: ReturnType<typeof init> | null = null;

        const render = () => {
            const container = document.querySelector('#waline');

            if (!container) {
                if (walineInstance?.destroy) {
                    walineInstance.destroy();
                    walineInstance = null;
                }
                return;
            }

            if (walineInstance?.destroy) {
                walineInstance.destroy();
            }

            walineInstance = init({
                el: '#waline',
                serverURL: 'https://waline.reyar.top',
                path: window.location.pathname,
                lang: 'zh-CN',
                dark: 'auto',
                emoji: [
                    '//unpkg.com/@waline/emojis@latest/bilibili'
                ],
                meta: ['nick', 'mail'],
                requiredMeta: ['nick'],
                pageSize: 10,
            });
        };

        const onPageLoad = () => {
            queueMicrotask(render);
        };

        document.addEventListener('astro:after-swap', onPageLoad);
        document.addEventListener('astro:page-load', onPageLoad);

        return {
            render,
        };
    };

    const globalWindow = window as unknown as Record<string, ReturnType<typeof createManager>>;
    const manager = globalWindow[managerKey] ?? (globalWindow[managerKey] = createManager());

    manager.render();
</script>

<style>
    #waline {
        margin-top: 2rem;
    }
</style>